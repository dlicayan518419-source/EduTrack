@model EduTrack.Models.ConductRecord

@{
    ViewData["Title"] = "Add Conduct Record";
    var students = ViewBag.Students as IEnumerable<dynamic> ?? new List<dynamic>();
    var staff = ViewBag.Staff as IEnumerable<dynamic> ?? new List<dynamic>();
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Add Conduct Record</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div class="mb-3">
                            <label asp-for="StudentID" class="form-label">Student</label>
                            <select asp-for="StudentID" class="form-select" required>
                                <option value="">Select Student</option>
                                @foreach (var student in students)
                                {
                                    <option value="@student.StudentID">@student.FullName</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Type" class="form-label">Behavior Type</label>
                            <select asp-for="Type" class="form-select" required>
                                <option value="Positive">Positive (Good Behavior)</option>
                                <option value="Negative">Negative (Misconduct)</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3" required placeholder="Describe the behavior..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ActionTaken" class="form-label">Action Taken</label>
                            <textarea asp-for="ActionTaken" class="form-control" rows="2" placeholder="e.g., Verbal warning, Parent notified, etc."></textarea>
                        </div>
                        <div class="mb-3">
                            <label asp-for="RecordedBy" class="form-label">Recorded By</label>
                            <select asp-for="RecordedBy" class="form-select" required>
                                <option value="">Select Staff</option>
                                @foreach (var staffMember in staff)
                                {
                                    <option value="@staffMember.StaffID">@staffMember.FullName (@staffMember.StaffRole)</option>
                                }
                            </select>
                        </div>
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Save Record</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>