@{
    ViewData["Title"] = "Conduct Records";
    var conductRecords = Model as IEnumerable<dynamic> ?? new List<dynamic>();
}

<div class="container">
    <div class="card">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="fas fa-clipboard-list me-2"></i>Conduct Records</h4>
            <a asp-action="Create" class="btn btn-light btn-sm">
                <i class="fas fa-plus me-1"></i> Add Record
            </a>
        </div>
        <div class="card-body">
            <div class="table-container">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Student</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Action Taken</th>
                            <th>Recorded By</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (conductRecords != null && conductRecords.Any())
                        {
                            foreach (var record in conductRecords)
                            {
                                <tr>
                                    <td>@record.Date.ToString("yyyy-MM-dd")</td>
                                    <td>@record.StudentName</td>
                                    <td>
                                        @if (record.Type == "Positive")
                                        {
                                            <span class="badge bg-success">Positive</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Negative</span>
                                        }
                                    </td>
                                    <td>@record.Description</td>
                                    <td>@record.ActionTaken</td>
                                    <td>@record.RecorderName (@record.RecorderRole)</td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@record.ConductID" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center">No conduct records found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>