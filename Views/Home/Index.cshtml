@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h4 class="mb-1">
                    <i class="fas fa-smile-wink me-2 text-primary"></i>
                    Welcome back, @ViewBag.Username!
                </h4>
                <p class="text-muted mb-0">
                    <i class="fas fa-id-badge me-1"></i> Role: <strong>@ViewBag.Role</strong>
                    <i class="fas fa-calendar-alt ms-3 me-1"></i> @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
                </p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-3">
        <div class="stat-card blue">
            <div class="stat-icon"><i class="fas fa-user-graduate"></i></div>
            <div class="stat-title">Total Students</div>
            <div class="stat-value">@ViewBag.StudentCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card green">
            <div class="stat-icon"><i class="fas fa-chalkboard-user"></i></div>
            <div class="stat-title">Teachers</div>
            <div class="stat-value">@ViewBag.TeacherCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card orange">
            <div class="stat-icon"><i class="fas fa-book"></i></div>
            <div class="stat-title">Currently Enrolled</div>
            <div class="stat-value">@ViewBag.EnrolledCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card teal">
            <div class="stat-icon"><i class="fas fa-coins"></i></div>
            <div class="stat-title">Total Collections</div>
            <div class="stat-value">₱@ViewBag.TotalCollections</div>
        </div>
    </div>
</div>