<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduTrack</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/site.css" />
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="logo">
            <img src="/images/LogoIt15.png" alt="EduTrack Logo" class="logo-img" onerror="this.src='https://via.placeholder.com/40?text=E'" />
            <span>EduTrack</span>
        </div>

        <!-- Dashboard -->
        <a href="@Url.Action("Index", "Home")" class="sidebar-link">
            <i class="fas fa-tachometer-alt"></i> <span>Dashboard</span>
        </a>

        <!-- Student Management -->
        @if (Context.Session.GetString("Role") == "Admin" || Context.Session.GetString("Role") == "Principal" || Context.Session.GetString("Role") == "Registrar")
        {
            <div class="sidebar-divider">Student Management</div>
            <a href="@Url.Action("Index", "Student")" class="sidebar-link">
                <i class="fas fa-user-graduate"></i> <span>Students</span>
            </a>
            <a href="@Url.Action("Index", "Enrollment")" class="sidebar-link">
                <i class="fas fa-book-open"></i> <span>Enrollments</span>
            </a>
        }

        <!-- Attendance -->
        @if (Context.Session.GetString("Role") == "Admin" || Context.Session.GetString("Role") == "Principal" || Context.Session.GetString("Role") == "Teacher")
        {
            <div class="sidebar-divider">Attendance</div>
            <a href="@Url.Action("Student", "Attendance")" class="sidebar-link">
                <i class="fas fa-calendar-check"></i> <span>Student Attendance</span>
            </a>
            <a href="@Url.Action("Staff", "Attendance")" class="sidebar-link">
                <i class="fas fa-clock"></i> <span>Staff Attendance</span>
            </a>
        }

        <!-- Academics -->
        @if (Context.Session.GetString("Role") == "Admin" || Context.Session.GetString("Role") == "Principal" || Context.Session.GetString("Role") == "Teacher")
        {
            <div class="sidebar-divider">Academics</div>
            <a href="@Url.Action("EnterGrades", "Grade")" class="sidebar-link">
                <i class="fas fa-chalkboard"></i> <span>Enter Grades</span>
            </a>
            <a href="@Url.Action("Index", "Grade")" class="sidebar-link">
                <i class="fas fa-chart-line"></i> <span>View Grades</span>
            </a>
        }

        <!-- Student Welfare -->
        @if (Context.Session.GetString("Role") == "Admin" || Context.Session.GetString("Role") == "Principal" || Context.Session.GetString("Role") == "Guidance" || Context.Session.GetString("Role") == "Teacher")
        {
            <div class="sidebar-divider">Student Welfare</div>
            <a href="@Url.Action("Index", "Conduct")" class="sidebar-link">
                <i class="fas fa-clipboard-list"></i> <span>Conduct Records</span>
            </a>
            <a href="@Url.Action("Index", "Health")" class="sidebar-link">
                <i class="fas fa-notes-medical"></i> <span>Health Records</span>
            </a>
        }

        <!-- Financial -->
        @if (Context.Session.GetString("Role") == "Admin" || Context.Session.GetString("Role") == "Principal" || Context.Session.GetString("Role") == "Cashier" || Context.Session.GetString("Role") == "Accounting")
        {
            <div class="sidebar-divider">Financial</div>
            <a href="@Url.Action("Index", "Billing")" class="sidebar-link">
                <i class="fas fa-coins"></i> <span>Billing & Payments</span>
            </a>
            <a href="@Url.Action("Dashboard", "Budget")" class="sidebar-link">
                <i class="fas fa-chart-line"></i> <span>Budget Management</span>
            </a>
        }

        <!-- Reports & Analytics -->
        @if (Context.Session.GetString("Role") == "Admin" || Context.Session.GetString("Role") == "Principal")
        {
            <div class="sidebar-divider">Reports & Analytics</div>
            <a href="@Url.Action("ExecutiveSummary", "Report")" class="sidebar-link">
                <i class="fas fa-chart-pie"></i> <span>Executive Summary</span>
            </a>
            <a href="@Url.Action("KPIDashboard", "Report")" class="sidebar-link">
                <i class="fas fa-chart-line"></i> <span>KPI Dashboard</span>
            </a>
            <a href="@Url.Action("StudentPerformance", "Report")" class="sidebar-link">
                <i class="fas fa-chart-bar"></i> <span>Student Performance</span>
            </a>
            <a href="@Url.Action("FinancialSummary", "Report")" class="sidebar-link">
                <i class="fas fa-chart-line"></i> <span>Financial Summary</span>
            </a>
            <a href="@Url.Action("BudgetReport", "Budget")" class="sidebar-link">
                <i class="fas fa-chart-line"></i> <span>Budget Report</span>
            </a>
        }

        <!-- System Admin -->
        @if (Context.Session.GetString("Role") == "Admin")
        {
            <div class="sidebar-divider">System</div>
            <a href="@Url.Action("Dashboard", "Admin")" class="sidebar-link">
                <i class="fas fa-cog"></i> <span>Admin Panel</span>
            </a>
            <a href="@Url.Action("Users", "Admin")" class="sidebar-link">
                <i class="fas fa-users"></i> <span>User Management</span>
            </a>
            <a href="@Url.Action("SystemLogs", "Admin")" class="sidebar-link">
                <i class="fas fa-history"></i> <span>System Logs</span>
            </a>
        }

        <!-- User Section -->
        <div class="sidebar-divider">Account</div>
        <a href="@Url.Action("Logout", "Account")" class="sidebar-link">
            <i class="fas fa-sign-out-alt"></i> <span>Logout</span>
        </a>

        <!-- Sidebar Footer with User Info -->
        <div class="sidebar-footer">
            <div class="user-info-sidebar">
                <i class="fas fa-user-circle"></i>
                <div>
                    <div class="user-name">@Context.Session.GetString("Username")</div>
                    <div class="user-role">@Context.Session.GetString("Role")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        <div class="navbar-top">
            <div>
                <i class="fas fa-graduation-cap"></i> EduTrack Elementary
                <small class="ms-2">@DateTime.Now.ToString("yyyy-MM-dd")</small>
            </div>
            <div>
                <span class="badge bg-light text-dark">School Year: 2025-2026</span>
            </div>
        </div>

        @RenderBody()

        <footer class="footer">
            EduTrack © @DateTime.Now.Year - Elementary School Management System
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>