@model IEnumerable<EduTrack.Models.Staff>

@{
    ViewData["Title"] = "Staff Management";
}

<div class="container">
    <div class="card">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="fas fa-users me-2"></i>Staff Management</h4>
            <a asp-action="Create" class="btn btn-light btn-sm">
                <i class="fas fa-plus me-1"></i> Add New Staff
            </a>
        </div>
        <div class="card-body">
            <div class="table-container">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Role</th>
                            <th>Hire Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var staff in Model)
                        {
                            <tr>
                                <td>@staff.StaffID</td>
                                <td>@staff.FirstName</td>
                                <td>@staff.LastName</td>
                                <td>@staff.StaffRole</td>
                                <td>@(staff.HireDate?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                                <td>
                                    <a asp-action="Update" asp-route-id="@staff.StaffID" class="btn btn-sm btn-outline-warning">
                                        <i class="fas fa-edit"></i> Update
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>