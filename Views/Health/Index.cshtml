@model IEnumerable<EduTrack.Models.HealthRecord>

@{
    ViewData["Title"] = "Health Records";
}

<div class="container">
    <div class="card">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="fas fa-notes-medical me-2"></i>Health Records</h4>
            <a asp-action="Create" class="btn btn-light btn-sm">
                <i class="fas fa-plus me-1"></i> Add Record
            </a>
        </div>
        <div class="card-body">
            <div class="table-container">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Student</th>
                            <th>Visit Type</th>
                            <th>Description</th>
                            <th>Diagnosis</th>
                            <th>Follow Up</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in Model)
                        {
                            <tr>
                                <td>@record.Date.ToString("yyyy-MM-dd")</td>
                                <td>@record.Student?.FirstName @record.Student?.LastName</td>
                                <td>@record.VisitType</td>
                                <td>@record.Description</td>
                                <td>@record.Diagnosis</td>
                                <td>@record.FollowUp</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>