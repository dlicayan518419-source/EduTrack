@model IEnumerable<EduTrack.Models.SystemLog>

@{
    ViewData["Title"] = "System Logs";
}

<div class="container mt-4">
    <h2>System Logs (Last 100)</h2>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Timestamp</th>
                <th>User</th>
                <th>Action</th>
                <th>IP Address</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@log.User?.Username</td>
                    <td>@log.Action</td>
                    <td>@log.IPAddress</td>
                    <td>@log.Details</td>
                </tr>
            }
        </tbody>
    </table>
</div>