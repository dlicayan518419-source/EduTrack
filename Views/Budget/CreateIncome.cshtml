@model EduTrack.Models.FinancialTransaction

@{
    ViewData["Title"] = "Add Income";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Add Income</h4>
                </div>
                <div class="card-body">
                    <form asp-action="CreateIncome">
                        <div class="mb-3">
                            <label asp-for="Category" class="form-label">Category</label>
                            <select asp-for="Category" class="form-select">
                                <option value="Tuition Fees">Tuition Fees</option>
                                <option value="Miscellaneous">Miscellaneous</option>
                                <option value="Donations">Donations</option>
                                <option value="Others">Others</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label">Amount</label>
                            <input asp-for="Amount" type="number" step="0.01" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="d-flex justify-content-between">
                            <a asp-action="Income" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-success">Save Income</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>