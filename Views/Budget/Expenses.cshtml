@model IEnumerable<EduTrack.Models.FinancialTransaction>

@{
    ViewData["Title"] = "Expenses";
}

<div class="container">
    <div class="card">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="fas fa-minus-circle me-2"></i>Expense Transactions</h4>
            <a asp-action="CreateExpense" class="btn btn-light btn-sm">
                <i class="fas fa-plus me-1"></i> Add Expense
            </a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Amount</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Date.ToString("yyyy-MM-dd")</td>
                                    <td>@item.Category</td>
                                    <td><span class="text-danger fw-bold">₱@item.Amount.ToString("N2")</span></td>
                                    <td>@item.Description</td>
                                 </tr>
                            }
                        }
                        else
                        {
                             <tr>
                                 <td colspan="4" class="text-center">No expense transactions found.</td>
                             </tr>
                        }
                    </tbody>
                 </table>
            </div>
            <a asp-action="Dashboard" class="btn btn-secondary mt-3">Back to Dashboard</a>
        </div>
    </div>
</div>