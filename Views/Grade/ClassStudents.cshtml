@{
    ViewData["Title"] = "Enter Grades";
    var classInfo = ViewBag.Class as EduTrack.Models.Class;
    var students = ViewBag.Students as List<EduTrack.Models.Student>;
    var grades = ViewBag.Grades as Dictionary<int, decimal?>;
    var quarter = ViewBag.Quarter;
}

<div class="container mt-4">
    <h2>Enter Grades - @(classInfo?.Subject?.SubjectName ?? "Unknown Subject")</h2>
    <h4>@(classInfo?.Section?.GradeLevel?.GradeName ?? "Unknown Grade") - Section @(classInfo?.Section?.SectionName ?? "Unknown")</h4>
    <h5>Quarter @quarter</h5>

    <form method="post" asp-action="SaveGrades">
        <input type="hidden" name="classId" value="@(classInfo?.ClassID)" />
        <input type="hidden" name="quarter" value="@quarter" />

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Student Name</th>
                    <th>Score (0-100)</th>
                </tr>
            </thead>
            <tbody>
                @if (students != null && students.Any())
                {
                    for (int i = 0; i < students.Count; i++)
                    {
                        var student = students[i];
                        var currentGrade = grades != null && grades.ContainsKey(student.StudentID) ? grades[student.StudentID] : null;
                        <tr>
                            <td>
                                @student.FirstName @student.LastName
                                <input type="hidden" name="studentIds" value="@student.StudentID" />
                            </td>
                            <td>
                                <input type="number" name="scores" value="@(currentGrade.HasValue? currentGrade.Value.ToString() : "")" class="form-control" min="0" max="100" step="0.01" required />
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="2" class="text-center">No students found in this class.</td>
                    </tr>
                }
            </tbody>
        </table>
        <button type="submit" class="btn btn-primary">Save Grades</button>
        <a asp-action="EnterGrades" class="btn btn-secondary">Back</a>
    </form>
</div>