@{
    ViewData["Title"] = "Make Payment";
    var billing = ViewBag.Billing as EduTrack.Models.Billing;
    var studentName = ViewBag.StudentName as string ?? "Unknown";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-money-bill me-2"></i>Make Payment</h4>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-5">Student</dt>
                        <dd class="col-sm-7">@studentName</dd>

                        <dt class="col-sm-5">Fee Type</dt>
                        <dd class="col-sm-7">@billing?.FeeType</dd>

                        <dt class="col-sm-5">Total Amount</dt>
                        <dd class="col-sm-7">₱@(billing?.Amount.ToString("N2") ?? "0.00")</dd>

                        <dt class="col-sm-5">Remaining Balance</dt>
                        <dd class="col-sm-7">
                            <span class="badge bg-danger fs-6">₱@(billing?.Balance.ToString("N2") ?? "0.00")</span>
                        </dd>
                    </dl>

                    <form asp-action="RecordPayment" method="post">
                        <input type="hidden" name="billingId" value="@billing?.BillingID" />
                        
                        <div class="mb-3">
                            <label class="form-label">Amount to Pay</label>
                            <input type="number" name="amountPaid" step="0.01" class="form-control"
                                   max="@billing?.Balance" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Reference Number (Optional)</label>
                            <input type="text" name="referenceNumber" class="form-control" placeholder="Check #, Transaction ID, etc." />
                        </div>
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Process Payment</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>